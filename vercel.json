{
  "version": 2,
  "builds": [
    { "src": "api/ebay-listings.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/ebay-listings", "dest": "/api/ebay-listings.js" },
    { "handle": "filesystem" },
    { "src": "/", "dest": "/index.html" }
  ]
}
